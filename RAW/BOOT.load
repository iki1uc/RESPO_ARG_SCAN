async function BOOTload() {
    window.ROMPOOL = {};

    const romFiles = [
        "RAW/ROM/3x3x3.raw",
        "RAW/ROM/81.room",
        "RAW/ROM/9hoch9.room",
        "RAW/ROM/ROM.build",
        "RAW/ROM/Pipeline.rom"
    ];

    for (const file of romFiles) {
        try {
            const res = await fetch(file);
            const buf = await res.arrayBuffer();
            ROMPOOL[file] = new Uint8Array(buf);
        } catch {
            ROMPOOL[file] = null;
        }
    }
}
