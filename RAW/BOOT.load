async function BOOTload() {
    window.ROMPOOL = {};

    const files = [
        "RAW/ROM/3x3x3.raw",
        "RAW/ROM/81.room",
        "RAW/ROM/9hoch9.room",
        "RAW/ROM/ROM.build",
        "RAW/µ.raw",
        "RAW/HW.raw"
    ];

    for (const f of files) {
        try {
            const res = await fetch(f);
            const buf = await res.arrayBuffer();
            ROMPOOL[f] = new Uint8Array(buf);
        } catch {
            ROMPOOL[f] = null;
        }
    }
}

